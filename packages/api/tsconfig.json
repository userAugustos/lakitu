{
  "extends": "@lakitu/tsconfig/base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "paths": {
      "@api/*": ["./src/*"],
      "@core/*": ["./src/modules/core/*"]
    },
    "jsx": "react-jsx",
    "types": ["bun-types"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
