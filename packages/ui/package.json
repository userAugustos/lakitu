{
  "name": "@repo/ui",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": "./src/*",
    "./styles": "./src/styles/index.css",
    "./utils": "./src/lib/utils.ts",
    "./shadcn/*": [
      "./src/shadcn/*.tsx",
      "./src/shadcn/*.ts",
      "./src/shadcn/*/index.tsx",
      "./src/shadcn/*/index.ts"
    ],
    "./components/*": [
      "./src/components/*.tsx",
      "./src/components/*/index.tsx",
      "./src/components/*/index.ts"
    ],
    "./hooks/*": [
      "./src/hooks/*.ts",
      "./src/hooks/*.tsx"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "input-otp": "^1.4.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.1",
    "tw-animate-css": "^1.2.4"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "@lakitu/tsconfig": "*",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.11",
    "typescript": "5.9.3"
  }
}
